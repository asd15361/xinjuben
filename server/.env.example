# 阿里云正式部署配置
APP_ID=xinjuben
POCKETBASE_URL=https://your-aliyun-pocketbase-domain
PB_ADMIN_EMAIL=your-pocketbase-admin-email
PB_ADMIN_PASSWORD=your-pocketbase-admin-password
PAYMENT_MODE=live
ALIPAY_LIVE_ENABLED=1
ALIPAY_APP_ID=2021006133603144
ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do
ALIPAY_PUBLIC_KEY=your-alipay-public-key
ALIPAY_PRIVATE_KEY=your-alipay-private-key
ALIPAY_NOTIFY_URL=https://your-aliyun-domain/api/pay/webhook/alipay
ALIPAY_RETURN_URL=https://your-aliyun-domain/
ALIPAY_MERCHANT_PUBLIC_KEY=

# 服务器配置
PORT=3000
NODE_ENV=development

