DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_SYSTEM_INSTRUCTION=
DEEPSEEK_TIMEOUT_MS=45000

GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com
GEMINI_FLASH_MODEL=gemini-2.5-flash
GEMINI_PRO_MODEL=gemini-2.5-pro
GEMINI_SYSTEM_INSTRUCTION=
GEMINI_TIMEOUT_MS=45000

MODEL_ROUTER_ENABLE_DEEPSEEK=1
MODEL_ROUTER_ENABLE_GEMINI_FLASH=1
MODEL_ROUTER_ENABLE_GEMINI_PRO=1
RUNTIME_FETCH_TIMEOUT_MS=15000

# Development only: when enabled, AI calls return deterministic local mock output.
MOCK_AI_ENABLE=0
